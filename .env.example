# Environment Configuration Example

# Copy this file to .env (not tracked in git) and fill in your values

# API Configuration
API_BASE_URL=https://jsonplaceholder.typicode.com
API_TIMEOUT=30

# Feature Flags (optional)
ENABLE_LOGGING=true
ENABLE_ANALYTICS=false

# Build Configuration
APP_NAME=BlocCI/CD
APP_VERSION=1.0.0

